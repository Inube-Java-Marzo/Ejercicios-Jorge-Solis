select * from CLIENTES_TEST;

-- Simulamos la perdida de la tabla

TRUNCATE TABLE CLIENTES_TEST;

--Restauramos desde la Bitácora

INSERT INTO CLIENTES_TEST (ID, NOMBRE, RFC, FECHA_ALTA)
SELECT ID, NOMBRE, RFC, FECHA_ALTA
FROM (
    SELECT b.*,
           ROW_NUMBER() OVER (PARTITION BY ID ORDER BY FECHA_MOV DESC) rn
    FROM CLIENTES_TEST_BIT b
)
WHERE rn = 1;

COMMIT;
