-- Crear tabla

CREATE TABLE CLIENTES_TEST (
    ID NUMBER PRIMARY KEY,
    NOMBRE VARCHAR2(50),
    RFC VARCHAR2(13),
    FECHA_ALTA DATE DEFAULT SYSDATE
);

--Crear Bitácora

CREATE TABLE CLIENTES_TEST_BIT (
    ID_BIT NUMBER PRIMARY KEY,
    ID NUMBER,
    NOMBRE VARCHAR2(50),
    RFC VARCHAR2(13),
    FECHA_ALTA DATE,
    ACCION VARCHAR2(10),
    FECHA_MOV DATE DEFAULT SYSDATE
);

--Secuencia

CREATE SEQUENCE SEQ_CLIENTES_TEST_BIT START WITH 1 INCREMENT BY 1;

--Triggers

CREATE OR REPLACE TRIGGER TRG_CLIENTES_TEST_AUD
AFTER INSERT OR UPDATE OR DELETE ON CLIENTES_TEST
FOR EACH ROW
BEGIN
    IF INSERTING THEN
        INSERT INTO CLIENTES_TEST_BIT
        VALUES (
            SEQ_CLIENTES_TEST_BIT.NEXTVAL,
            :NEW.ID,
            :NEW.NOMBRE,
            :NEW.RFC,
            :NEW.FECHA_ALTA,
            'INSERT',
            SYSDATE
        );

    ELSIF UPDATING THEN
        INSERT INTO CLIENTES_TEST_BIT
        VALUES (
            SEQ_CLIENTES_TEST_BIT.NEXTVAL,
            :NEW.ID,
            :NEW.NOMBRE,
            :NEW.RFC,
            :NEW.FECHA_ALTA,
            'UPDATE',
            SYSDATE
        );

    ELSIF DELETING THEN
        INSERT INTO CLIENTES_TEST_BIT
        VALUES (
            SEQ_CLIENTES_TEST_BIT.NEXTVAL,
            :OLD.ID,
            :OLD.NOMBRE,
            :OLD.RFC,
            :OLD.FECHA_ALTA,
            'DELETE',
            SYSDATE
        );
    END IF;
END;
/

